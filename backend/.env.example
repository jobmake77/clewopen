# 服务器配置
PORT=5000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clewopen
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=info

# 文件上传配置
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads/agents

# Agent 试用 LLM 配置（用于自动写入并激活 llm_configs）
AI_PROVIDER=openai
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_REQUEST_TIMEOUT_MS=45000
AI_AUTH_TYPE=bearer
AI_ENABLE_STREAM=false
AI_REASONING_EFFORT=
AI_INCLUDE_MAX_COMPLETION_TOKENS=false
AI_INCLUDE_MAX_OUTPUT_TOKENS=false
AI_LEGACY_OPENAI_FORMAT=true

# Kimi Code 兼容示例（保留兼容，但不建议用作 OpenCLEW 云端试用主 provider）
# AI_PROVIDER=kimi
# AI_BASE_URL=https://api.kimi.com/coding/v1
# AI_MODEL=kimi-for-coding
# AI_MAX_TOKENS=32768
# AI_REQUEST_TIMEOUT_MS=60000
# AI_AUTH_TYPE=bearer
# AI_ENABLE_STREAM=true
# AI_REASONING_EFFORT=medium
# AI_INCLUDE_MAX_COMPLETION_TOKENS=true
# AI_LEGACY_OPENAI_FORMAT=true

# Trial runtime 配置
# prompt: 当前基于 LLM prompt 的轻量试用
# container: 使用独立 Docker session 容器执行
TRIAL_RUNTIME_MODE=prompt
TRIAL_WORKSPACE_ROOT=/tmp/openclew/trial-sessions

# 容器化 trial sandbox 配置
TRIAL_SANDBOX_IMAGE=openclew/trial-base:latest
TRIAL_SANDBOX_MOUNT_PATH=/workspace
# OpenClaw embedded agent needs egress to reach the model provider.
# Production should replace bridge with a dedicated egress-controlled Docker network.
TRIAL_SANDBOX_NETWORK=bridge
TRIAL_SANDBOX_MEMORY=1536m
TRIAL_SANDBOX_CPUS=1
TRIAL_SANDBOX_PIDS_LIMIT=256
TRIAL_SANDBOX_READONLY_ROOTFS=false
TRIAL_SANDBOX_EXEC_TIMEOUT_MS=180000
TRIAL_SANDBOX_KEEP_FAILED_SESSIONS=false
TRIAL_SANDBOX_SHELL=/bin/sh
TRIAL_SANDBOX_DOCKER_BIN=/usr/local/bin/docker
TRIAL_SANDBOX_DOCKER_HELPER_PATH=/Applications/Docker.app/Contents/Resources/bin
TRIAL_SANDBOX_BASE_IMAGE=node:22-bookworm-slim

# 容器内安装/运行命令
TRIAL_SANDBOX_INSTALL_COMMAND=/opt/openclew/bin/session-runner.sh install
TRIAL_SANDBOX_RUN_COMMAND=/opt/openclew/bin/session-runner.sh run
TRIAL_OPENCLAW_NODE_OPTIONS=--max-old-space-size=1024

# 构建基础镜像时用于预装 OpenCLEW CLI 的命令
# 默认构建脚本会使用官方 npm 包:
# npm install -g openclaw@${OPENCLAW_CLI_VERSION}
# 如需改成私有分发，覆盖下面这个命令即可
OPENCLEW_INSTALL_COMMAND=
OPENCLAW_CLI_VERSION=2026.3.12
