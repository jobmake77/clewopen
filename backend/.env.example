# 服务器配置
PORT=5000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clewopen
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=info

# 文件上传配置
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads/agents
