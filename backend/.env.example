# 服务器配置
PORT=5000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clewopen
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=info
SECRET_ENCRYPTION_KEY=

# 文件上传配置
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads/agents

# Agent 试用 LLM 配置（用于自动写入并激活 llm_configs）
AI_PROVIDER=openai
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_REQUEST_TIMEOUT_MS=45000
AI_AUTH_TYPE=bearer
AI_ENABLE_STREAM=false
AI_REASONING_EFFORT=
AI_INCLUDE_MAX_COMPLETION_TOKENS=false
AI_INCLUDE_MAX_OUTPUT_TOKENS=false
AI_LEGACY_OPENAI_FORMAT=true

# Kimi Code 兼容示例（保留兼容，但不建议用作 OpenCLEW 云端试用主 provider）
# AI_PROVIDER=kimi
# AI_BASE_URL=https://api.kimi.com/coding/v1
# AI_MODEL=kimi-for-coding
# AI_MAX_TOKENS=32768
# AI_REQUEST_TIMEOUT_MS=60000
# AI_AUTH_TYPE=bearer
# AI_ENABLE_STREAM=true
# AI_REASONING_EFFORT=medium
# AI_INCLUDE_MAX_COMPLETION_TOKENS=true
# AI_LEGACY_OPENAI_FORMAT=true

# Trial runtime 配置
# prompt: 当前基于 LLM prompt 的轻量试用
# container: 使用独立 Docker session 容器执行
TRIAL_RUNTIME_MODE=prompt
TRIAL_WORKSPACE_ROOT=/tmp/openclew/trial-sessions

# 容器化 trial sandbox 配置
TRIAL_SANDBOX_IMAGE=openclew/trial-base:latest
TRIAL_SANDBOX_MOUNT_PATH=/workspace
# OpenClaw embedded agent needs egress to reach the model provider.
# Production should replace bridge with a dedicated egress-controlled Docker network.
TRIAL_SANDBOX_NETWORK=bridge
TRIAL_SANDBOX_MEMORY=1536m
TRIAL_SANDBOX_CPUS=1
TRIAL_SANDBOX_PIDS_LIMIT=256
TRIAL_SANDBOX_READONLY_ROOTFS=false
TRIAL_SANDBOX_EXEC_TIMEOUT_MS=180000
TRIAL_SANDBOX_KEEP_FAILED_SESSIONS=false
TRIAL_SANDBOX_SHELL=/bin/sh
TRIAL_SANDBOX_DOCKER_BIN=/usr/local/bin/docker
TRIAL_SANDBOX_DOCKER_HELPER_PATH=/Applications/Docker.app/Contents/Resources/bin
TRIAL_SANDBOX_BASE_IMAGE=node:22-bookworm-slim

# 容器内安装/运行命令
TRIAL_SANDBOX_INSTALL_COMMAND=/opt/openclew/bin/session-runner.sh install
TRIAL_SANDBOX_PREWARM_COMMAND=/opt/openclew/bin/session-runner.sh prewarm-gateway
TRIAL_SANDBOX_RUN_COMMAND=/opt/openclew/bin/session-runner.sh run
TRIAL_OPENCLAW_NODE_OPTIONS=--max-old-space-size=1024

# Warm sandbox pool（生产建议：开启，预热 5 个实例）
TRIAL_POOL_ENABLED=true
TRIAL_POOL_SIZE=5
TRIAL_POOL_ACQUIRE_TIMEOUT_MS=15000
TRIAL_POOL_MAINTENANCE_INTERVAL_MS=10000
TRIAL_POOL_BOOTSTRAP_CONCURRENCY=2
TRIAL_POOL_GATEWAY_HOT_SIZE=2
TRIAL_POOL_RECYCLE_AFTER_SESSIONS=30
# 默认会自动使用 hostname + PORT 生成 namespace；只有多实例共享同一 Docker 宿主机时才需要手动覆盖
# TRIAL_POOL_NAMESPACE=prod-main-5000
# 默认会落到 backend/.trial-runtime/trial-pool/<namespace>
# TRIAL_POOL_WORKSPACE_ROOT=/srv/clewopen/trial-pool

# 构建基础镜像时用于预装 OpenCLEW CLI 的命令
# 默认构建脚本会使用官方 npm 包:
# npm install -g openclaw@${OPENCLAW_CLI_VERSION}
# 如需改成私有分发，覆盖下面这个命令即可
OPENCLEW_INSTALL_COMMAND=
OPENCLAW_CLI_VERSION=2026.3.12

# 定制开发交付仓库（禁止外链交付，统一上传 ZIP 到私有仓库）
# 例如：jobmake77/clewopen-repo
CUSTOM_ORDER_ARTIFACT_REPO=jobmake77/clewopen-repo

# Skill/MCP 自动同步调度（分钟）
# 例：每 60 分钟同步一次
SYNC_INTERVAL_MINUTES=1440
# 启动后是否立即执行一次同步
SYNC_RUN_ON_START=true
# GitHub Token（强烈建议配置，能显著提高 API 速率额度）
GITHUB_TOKEN=
# 每个关键词最大抓取页数（每页由 SYNC_GITHUB_PER_PAGE 控制）
SYNC_GITHUB_MAX_PAGES=10
# GitHub Search 每页条数（最大 100）
SYNC_GITHUB_PER_PAGE=100
# GitHub 请求间隔（毫秒）
SYNC_GITHUB_REQUEST_INTERVAL_MS=1200
# 单轮同步最大 GitHub 请求数（建议日常 120，回填 240+）
SYNC_GITHUB_MAX_REQUESTS_PER_RUN=120
# OpenClaw 每轮分片用户数（建议日常 120，回填 300+）
SYNC_OPENCLAW_BATCH_SIZE=120
# OpenClaw 首轮加速倍数（仅 offset=0 时生效）
SYNC_OPENCLAW_BOOTSTRAP_MULTIPLIER=3

# 合规公开信息（用于前端合规页面展示）
DATA_STORAGE_REGION=香港
OBJECT_STORAGE_REGION=香港
BACKUP_STORAGE_REGION=香港
THIRD_PARTY_PROVIDERS=OpenAI-compatible API 网关,GitHub,OpenClaw Skills Registry
DOMESTIC_MIGRATION_PLAN=支持切换到中国内地节点（数据库迁移 + 对象存储迁移 + DNS 灰度）
COMPLIANCE_CONTACT_EMAIL=compliance@clewopen.com
COMPLAINT_CONTACT_EMAIL=abuse@clewopen.com
POLICY_VERSION=2026-03-19

# 数据保留与自动清理（建议：试用消息 30 天，访问日志 90 天）
DATA_RETENTION_ENABLED=true
DATA_RETENTION_INTERVAL_MS=86400000
TRIAL_MESSAGE_RETENTION_DAYS=30
TRIAL_SESSION_RETENTION_DAYS=30
ACCESS_LOG_RETENTION_DAYS=90
NOTIFICATION_RETENTION_DAYS=90
LOG_FILE_RETENTION_DAYS=30
TRIAL_WORKSPACE_RETENTION_DAYS=30
