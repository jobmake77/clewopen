# Server
PORT=5000
NODE_ENV=production

# Database (Supabase)
# Recommended: use transaction pooler URL
# Example host for this project:
# aws-1-ap-southeast-1.pooler.supabase.com
DATABASE_URL=postgresql://postgres.iopjdhegiepslmnyhzgo:<YOUR_DB_PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Optional: for REST-based readiness checks (no DB password needed)
SUPABASE_URL=https://iopjdhegiepslmnyhzgo.supabase.co
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# CORS (frontend on Vercel)
CORS_ORIGINS=https://your-frontend.vercel.app

# Logging
LOG_LEVEL=info

# Auth
AUTH_FRONTEND_BASE_URL=https://clewopen.com
AUTH_PUBLIC_BASE_URL=https://clewopen.com
EMAIL_CODE_SECRET=replace_with_random_secret
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@clewopen.com
RESEND_API_KEY=
RESEND_FROM=no-reply@clewopen.com
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://clewopen.com/api/auth/github/callback

# Keep existing AI / Trial / Sync variables from .env.example as needed
